<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.budget.backup</string>

  <key>ProgramArguments</key>
  <array>
    <string>/Users/diogolopes/dev/budget/nextjs-boilerplate/sync/backup/backup.sh</string>
  </array>

  <!-- Weekly: Friday 11:40 (Weekday 5). Separate from the 10:00 weekday bank
       syncs. If the Mac is OFF at that time the run is skipped (no catch-up); if
       ASLEEP, launchd runs it on the next wake — harmless, backups are idempotent
       and just produce a fresh timestamped archive. -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Weekday</key><integer>5</integer>
    <key>Hour</key><integer>11</integer>
    <key>Minute</key><integer>40</integer>
  </dict>

  <!-- Don't run on load/login, only on the schedule. -->
  <key>RunAtLoad</key>
  <false/>

  <key>StandardOutPath</key>
  <string>/Users/diogolopes/Library/Application Support/budget-sync/logs/backup.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/diogolopes/Library/Application Support/budget-sync/logs/backup.log</string>
</dict>
</plist>
